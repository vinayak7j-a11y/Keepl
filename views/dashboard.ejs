<!DOCTYPE html>
<html>

<head>

<title>Keepl Dashboard</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#2f80ed">

<style>

body{
font-family:Arial;
background:#f4f6f8;
padding:30px;
margin:0;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
flex-wrap:wrap;
gap:10px;
}

.header-buttons{
display:flex;
gap:10px;
flex-wrap:wrap;
}

h1{
margin:0;
font-size:24px;
}

button{
background:#2f80ed;
color:white;
border:none;
padding:10px 16px;
cursor:pointer;
border-radius:6px;
font-size:14px;
}

button:hover{
background:#1c60b3;
}

.logout{
background:#e74c3c;
}

.logout:hover{
background:#c0392b;
}

.stats{
display:flex;
gap:20px;
margin-bottom:25px;
flex-wrap:wrap;
}

.statBox{
background:white;
padding:20px;
border-radius:10px;
flex:1;
min-width:200px;
box-shadow:0 2px 6px rgba(0,0,0,0.05);
text-align:center;
}

.statBox p{
font-size:24px;
font-weight:bold;
margin-top:10px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
margin-bottom:25px;
box-shadow:0 2px 6px rgba(0,0,0,0.05);
}

table{
width:100%;
border-collapse:collapse;
}

th,td{
padding:12px;
border-bottom:1px solid #eee;
text-align:left;
}

th{
background:#fafafa;
}

.qrSection{
text-align:center;
}

.empty{
text-align:center;
padding:20px;
color:#777;
}

input{
padding:8px;
border-radius:6px;
border:1px solid #ddd;
width:120px;
}

.success{
color:green;
font-size:13px;
margin-top:5px;
}

.error{
color:red;
font-size:13px;
margin-top:5px;
}

#installBtn{
display:none;
}

@media(max-width:600px){

body{
padding:15px;
}

.statBox{
min-width:100%;
}

}

</style>

</head>

<body>

<div class="header">

<h1><%= shop.name %> Dashboard</h1>

<div class="header-buttons">

<button id="installBtn">
Install App
</button>

<a href="/poster/<%= shop.shopId %>">
<button>Download QR Poster</button>
</a>

<button class="logout" onclick="logout()">
Logout
</button>

</div>

</div>


<div class="stats">

<div class="statBox">
<h3>Customers Today</h3>
<p><%= customersToday %></p>
</div>

<div class="statBox">
<h3>Points Given Today</h3>
<p><%= pointsToday %></p>
</div>

<div class="statBox">
<h3>Total Waiting</h3>
<p id="waitingCount"><%= customers.length %></p>
</div>

</div>


<div class="card">

<h3>Customers Waiting</h3>

<% if(customers.length === 0){ %>

<div class="empty">
No customers in queue
</div>

<% } else { %>

<table>

<tr>
<th>Name</th>
<th>Phone</th>
<th>Visits</th>
<th>Total Spent</th>
<th>Points</th>
<th>Action</th>
</tr>

<% customers.forEach(customer => { %>

<tr id="row-<%= customer.phone %>">

<td><%= customer.name || "Customer" %></td>
<td><%= customer.phone %></td>
<td><%= customer.visits || 0 %></td>
<td>₹<%= customer.totalSpent || 0 %></td>
<td><%= customer.points || 0 %></td>

<td>

<input 
type="number" 
id="amount-<%= customer.phone %>" 
placeholder="Bill Amount"
>

<button onclick="givePoints('<%= customer.phone %>', this)">
Give Points
</button>

<div id="msg-<%= customer.phone %>"></div>

</td>

</tr>

<% }) %>

</table>

<% } %>

</div>


<div class="card qrSection">

<h3>Your Shop QR</h3>

<img 
src="<%= shop.qrCode %>" 
width="200"
alt="Shop QR Code"
style="border-radius:10px;padding:10px;background:white;box-shadow:0 4px 10px rgba(0,0,0,0.08);">

<p>Customers scan this QR to earn rewards</p>

</div>


<script>

/* =========================
SESSION CHECK
========================= */

const token = localStorage.getItem("token")
const shopId = localStorage.getItem("shopId")

if(!token || !shopId){
window.location.href="/"
}


/* =========================
LOGOUT
========================= */

function logout(){

if(confirm("Are you sure you want to logout?")){

localStorage.removeItem("token")
localStorage.removeItem("shopId")
localStorage.removeItem("qrCode")

window.location.href="/"

}

}


/* =========================
ADD POINTS
========================= */

async function givePoints(phone,btn){

const amountInput = document.getElementById(`amount-${phone}`)
const billAmount = amountInput.value
const msgBox = document.getElementById(`msg-${phone}`)

if(!billAmount){

msgBox.innerHTML="<span class='error'>Enter bill amount</span>"
return

}

btn.disabled=true
btn.innerText="Processing..."

const shopId = "<%= shop.shopId %>"

try{

const res = await fetch("/api/add-transaction",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body: JSON.stringify({
phone,
shopId,
billAmount
})

})

const data = await res.json()

msgBox.innerHTML=`<span class="success">+${data.pointsEarned} points added</span>`

setTimeout(()=>{

const row = document.getElementById(`row-${phone}`)

if(row) row.remove()

const waiting = document.getElementById("waitingCount")

if(waiting && waiting.innerText > 0){
waiting.innerText = Number(waiting.innerText) - 1
}

},700)

}catch(err){

msgBox.innerHTML="<span class='error'>Error adding points</span>"

}

btn.disabled=false
btn.innerText="Give Points"

}


/* =========================
INSTALL APP
========================= */

let deferredPrompt;

window.addEventListener("beforeinstallprompt",(e)=>{

e.preventDefault();

deferredPrompt = e;

const installBtn = document.getElementById("installBtn");

installBtn.style.display="inline-block";

installBtn.onclick = async ()=>{

deferredPrompt.prompt();

const choice = await deferredPrompt.userChoice;

if(choice.outcome === "accepted"){
installBtn.style.display="none";
}

};

});


/* =========================
SERVICE WORKER
========================= */

if("serviceWorker" in navigator){

navigator.serviceWorker
.register("/sw.js")
.then(()=>console.log("Service Worker registered"))

}

</script>

</body>

</html> 


