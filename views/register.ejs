<!DOCTYPE html>
<html>
<head>
  <title>Keepl - Register Shop</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>

<h2>Register Your Shop</h2>

<form action="/api/shops/register" method="POST">

<input type="text" name="name" placeholder="Shop Name" required>
<br><br>

<input type="text" name="ownerName" placeholder="Owner Name" required>
<br><br>

<input type="tel" name="phone" placeholder="Phone Number" required>
<br><br>

<input type="password" name="password" placeholder="Password" required>
<br><br>

<button type="submit">Register Shop</button>

</form>

</body>
</html>